HOST=0.0.0.0
PORT=8080
RUST_LOG=info,money_management_api=debug,tower_http=debug,axum=debug

# Supabase Postgres connection string (same as the Next.js app)
DATABASE_URL=

# Supabase project URL (Settings → API)
SUPABASE_URL=

# JWT secret for validating access tokens (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=

# Allowed Supabase Auth user email (must match the Next.js AUTH_USER_EMAIL)
AUTH_USER_EMAIL=

# Comma-separated origins for CORS (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Request timeout in seconds
REQUEST_TIMEOUT_SECS=30
