HOST=0.0.0.0
PORT=8080
RUST_LOG=info,money_management_api=debug,tower_http=debug,axum=debug

# Supabase Postgres connection string (same as the Next.js app).
# Use the SESSION-mode pooler (:5432) for both runtime AND migrations. RLS context is applied with
# session-level `set_config(..., false)` and the daily job uses session advisory locks — neither
# survives the transaction pooler (:6543), so do NOT use 6543 here.
# Diesel CLI does NOT load this file — source it first or use ./scripts/migrate.sh:
#   set -a && source .env && set +a && diesel migration run
# NOTE: the session pooler caps total clients at its configured pool_size (default 15, shared across
# every instance + the web app). Keep DB_POOL_MAX_SIZE well under that, or raise the pool size in
# the Supabase dashboard (Database → Connection pooling).
DATABASE_URL=

# Optional: path to a PEM CA bundle for verifying the database TLS cert. Leave unset to use the
# Supabase Root 2021 CA bundled in the binary (certs/supabase-root-2021-ca.pem). Set this to the
# `prod-ca-2021.crt` you download from the Supabase dashboard if/when the CA rotates.
# DATABASE_CA_CERT=/etc/secrets/supabase-ca.crt

# Supabase project URL (Settings → API). Used to fetch public signing keys from
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json (ES256 / P-256). Do NOT put your
# private signing key here — verification only needs the public key from JWKS.
SUPABASE_URL=

# Comma-separated origins for CORS (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Request timeout in seconds
REQUEST_TIMEOUT_SECS=30

# Rate limiting (per-IP on /api/v1, auth-failure, force-refresh). Off by default in
# debug builds (`cargo run`); on in release. Override with true/false.
# RATE_LIMIT_ENABLED=false

# Internal daily recurring-expense job (no HTTP endpoint)
ENABLE_INTERNAL_CRON=true
# Hour of day (0-23, server local time) to charge due recurring expenses
DAILY_EXPENSES_HOUR=0

# In-process read cache (moka). Revision keyed via user_settings.cache_revision.
# CACHE_ENABLED=true
# CACHE_MAX_ENTRIES=10000
# DB_POOL_MAX_SIZE=6
