HOST=0.0.0.0
PORT=8080
RUST_LOG=info,money_management_api=debug,tower_http=debug,axum=debug

# Supabase Postgres connection string (same as the Next.js app).
# Runtime: transaction pooler (:6543) is fine. Diesel migrations need session mode (:5432).
# Diesel CLI does NOT load this file — source it first or use ./scripts/migrate.sh:
#   set -a && source .env && set +a
#   export DATABASE_URL="${DATABASE_URL//:6543/:5432}" && diesel migration run
DATABASE_URL=

# Supabase project URL (Settings → API). Used to fetch public signing keys from
# {SUPABASE_URL}/auth/v1/.well-known/jwks.json (ES256 / P-256). Do NOT put your
# private signing key here — verification only needs the public key from JWKS.
SUPABASE_URL=

# Comma-separated origins for CORS (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Request timeout in seconds
REQUEST_TIMEOUT_SECS=30

# Internal daily recurring-expense job (no HTTP endpoint)
ENABLE_INTERNAL_CRON=true
# Hour of day (0-23, server local time) to charge due recurring expenses
DAILY_EXPENSES_HOUR=0
